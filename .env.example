NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Prisma database URLs
# Use a pooled DATABASE_URL for runtime (Neon pooled connection recommended)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"

# Use an unpooled DIRECT_URL for migrations (Prisma CLI needs direct access)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"
