generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  name            String
  username        String            @unique
  email           String?
  password        String
  role            Role              @default(CASHIER)
  pin             String?
  phone_number    String?
  status          String            @default("ACTIVE")
  profile_photo   String?
  employee_id     String?
  notes           String?
  last_login      DateTime?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  ordersCreated   Order[]           @relation("OrderCreatedBy")
  ordersProcessed Order[]           @relation("OrderProcessedBy")
  activityLogs    UserActivityLog[]
  shifts          UserShift[]

  @@map("user")
}

model UserActivityLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  action_type String
  description String?
  ip_address  String?
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_activity_log")
}

model UserShift {
  id                  Int       @id @default(autoincrement())
  user_id             Int
  start_time          DateTime  @default(now())
  end_time            DateTime?
  starting_cash       Int       @default(0)
  ending_cash         Int?
  expected_cash       Int?      @default(0)
  discrepancy         Int?      @default(0)
  note                String?
  cash_breakdown      Json?
  total_sales         Int       @default(0)
  status              String    @default("OPEN")
  reconciliation_data Json?
  user                User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([start_time])
  @@map("user_shift")
}

model StoreConfig {
  id                 Int      @id @default(autoincrement())
  store_name         String   @default("BAKMIE YOU-TJE")
  address            String?  @default("Jl. Bakung No. 123, Jakarta")
  phone              String?  @default("0812-3456-7890")
  receipt_footer     String?  @default("Thank you for visiting!\nPlease come again.")
  tax_rate           Float    @default(0)
  service_charge     Float    @default(0)
  updated_at         DateTime @updatedAt
  kitchen_auto_print Boolean  @default(false)
  kitchen_categories Json?    @default("[]")
  kitchen_copies     Int      @default(1)
  kitchen_enabled    Boolean  @default(true)
  paper_width        Int      @default(58)
  show_customer      Boolean  @default(true)
  show_logo          Boolean  @default(false)
  language           String   @default("en")
  instagram          String?
  logo_url           String?
  whatsapp           String?
  quick_tags         Json?    @default("[]")
  show_name          Boolean  @default(true)
  kitchen_delay      Int      @default(0)

  @@map("storeconfig")
}

model Menu {
  id         Int           @id @default(autoincrement())
  name       String
  price      Int
  created_at DateTime      @default(now())
  categoryId Int?
  is_active  Boolean       @default(true)
  cost       Int
  category   MenuCategory? @relation(fields: [categoryId], references: [id])
  prices     MenuPrice[]
  orderItems OrderItem[]
  recipe     Recipe?

  @@index([categoryId])
  @@index([name])
  @@map("menu")
}

model MenuCategory {
  id    Int          @id @default(autoincrement())
  name  String
  color String
  type  CategoryType @default(FOOD)
  menus Menu[]

  @@map("menucategory")
}

model Platform {
  id              Int          @id @default(autoincrement())
  name            String
  type            PlatformType @default(OFFLINE)
  commission_rate Float        @default(0)
  created_at      DateTime     @default(now())
  menuPrices      MenuPrice[]
  orders          Order[]

  @@map("platform")
}

model MenuPrice {
  id          Int      @id @default(autoincrement())
  menu_id     Int
  platform_id Int
  price       Int
  menu        Menu     @relation(fields: [menu_id], references: [id], onDelete: Cascade)
  platform    Platform @relation(fields: [platform_id], references: [id], onDelete: Cascade)

  @@unique([menu_id, platform_id])
  @@index([platform_id])
  @@map("menuprice")
}

model Order {
  id                   Int             @id @default(autoincrement())
  order_number         String?         @unique @default(uuid())
  date                 DateTime        @default(now())
  total                Int
  commission           Int             @default(0)
  net_revenue          Int             @default(0)
  platform_id          Int?
  payment_method       String          @default("CASH")
  money_received       Int             @default(0)
  change_amount        Int             @default(0)
  status               String          @default("COMPLETED")
  note                 String?
  customer_name        String?
  discount             Int             @default(0)
  created_by_user_id   Int?
  processed_by_user_id Int?
  payment_method_id    Int?
  discount_rate        Float           @default(0)
  discount_type        String          @default("FIXED")
  print_count          Int             @default(0)
  service_amount       Int             @default(0)
  service_rate         Float           @default(0)
  tax_amount           Int             @default(0)
  tax_rate             Float           @default(0)
  user                 User?           @relation("OrderCreatedBy", fields: [created_by_user_id], references: [id])
  paymentMethod        PaymentMethod?  @relation(fields: [payment_method_id], references: [id])
  platform             Platform?       @relation(fields: [platform_id], references: [id])
  processed_by         User?           @relation("OrderProcessedBy", fields: [processed_by_user_id], references: [id])
  orderItems           OrderItem[]
  stockMovements       StockMovement[]

  @@index([date])
  @@index([status])
  @@index([payment_method_id])
  @@index([platform_id])
  @@map("order")
}

model PaymentMethod {
  id             Int               @id @default(autoincrement())
  name           String
  type           PaymentMethodType @default(CASH)
  account_number String?
  account_name   String?
  description    String?
  is_active      Boolean           @default(true)
  display_order  Int               @default(0)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  qris_data      String?
  imageUrl       String?
  orders         Order[]

  @@map("paymentmethod")
}

model OrderItem {
  id       Int     @id @default(autoincrement())
  order_id Int
  menu_id  Int
  qty      Int
  price    Int
  cost     Int
  note     String?
  menu     Menu    @relation(fields: [menu_id], references: [id])
  order    Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([menu_id])
  @@index([order_id])
  @@index([price])
  @@map("orderitem")
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  item        String
  category    String
  amount      Int
  description String?

  @@map("expense")
}

model FixedCost {
  id        Int     @id @default(autoincrement())
  name      String
  amount    Int
  frequency String
  is_active Boolean @default(true)

  @@map("fixedcost")
}

model CashierReconciliation {
  id           Int      @id @default(autoincrement())
  date         DateTime @unique
  opening_cash Int      @default(0)
  closing_cash Int      @default(0)
  total_system Int      @default(0)
  total_actual Int      @default(0)
  discrepancy  Int      @default(0)
  notes        String?
  submitted_by String?
  status       String   @default("SUBMITTED")
  details      Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("cashierreconciliation")
}

model Ingredient {
  id                Int                      @id @default(autoincrement())
  unit              String
  cost_per_unit     Float                    @default(0)
  created_at        DateTime                 @default(now())
  updated_at        DateTime                 @updatedAt
  brand             String
  category          String
  item_name         String
  notes             String?
  price             Int
  purchase_link     String?
  purchase_location String?
  volume            Float
  minimum_stock     Float                    @default(0)
  stock             Float                    @default(0)
  price_history     IngredientPriceHistory[]
  purchases         Purchase[]
  recipe_items      RecipeItem[]
  stock_movements   StockMovement[]

  @@index([category])
  @@map("ingredient")
}

model IngredientPriceHistory {
  id                    Int        @id @default(autoincrement())
  ingredient_id         Int
  price                 Int
  date                  DateTime   @default(now())
  reference_purchase_id Int?
  change_percentage     Float?
  cost_per_unit         Float?     @default(0)
  vendor_name           String?
  ingredient            Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  purchase              Purchase?  @relation(fields: [reference_purchase_id], references: [id])

  @@map("ingredient_price_history")
}

model Purchase {
  id              Int                      @id @default(autoincrement())
  purchase_date   DateTime                 @default(now())
  ingredient_id   Int
  quantity        Float
  unit            String
  unit_price      Int
  total_price     Int
  supplier        String?
  notes           String?
  created_at      DateTime                 @default(now())
  volume          Float                    @default(1.0)
  price_histories IngredientPriceHistory[]
  ingredient      Ingredient               @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  stockMovements  StockMovement[]

  @@index([ingredient_id])
  @@map("purchase")
}

model StockMovement {
  id             Int          @id @default(autoincrement())
  ingredient_id  Int
  movement_type  MovementType
  quantity       Float
  unit           String
  reference_id   Int?
  reference_type String?
  created_at     DateTime     @default(now())
  order_id       Int?
  purchase_id    Int?
  ingredient     Ingredient   @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  order          Order?       @relation(fields: [order_id], references: [id])
  purchase       Purchase?    @relation(fields: [purchase_id], references: [id])

  @@index([ingredient_id])
  @@index([created_at])
  @@map("stock_movement")
}

model Recipe {
  id                        Int           @id @default(autoincrement())
  name                      String
  menu_id                   Int?          @unique
  base_quantity             Float         @default(1)
  total_variable_cost       Int           @default(0)
  fixed_cost_allocation     Int           @default(0)
  total_hpp                 Int           @default(0)
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt
  cost_change_alert         Float         @default(0)
  monthly_fixed_cost        Int           @default(0)
  monthly_production_volume Int           @default(0)
  type                      RecipeType    @default(STANDARD)
  snapshots                 HppSnapshot[]
  menu                      Menu?         @relation(fields: [menu_id], references: [id])
  used_in_items             RecipeItem[]  @relation("ComponentToItems")
  items                     RecipeItem[]  @relation("RecipeToItems")

  @@map("recipe")
}

model RecipeItem {
  id                  Int            @id @default(autoincrement())
  recipe_id           Int
  item_type           RecipeItemType @default(INGREDIENT)
  ingredient_id       Int?
  component_recipe_id Int?
  quantity            Float
  unit                String?
  component_recipe    Recipe?        @relation("ComponentToItems", fields: [component_recipe_id], references: [id])
  ingredient          Ingredient?    @relation(fields: [ingredient_id], references: [id])
  recipe              Recipe         @relation("RecipeToItems", fields: [recipe_id], references: [id], onDelete: Cascade)

  @@index([recipe_id])
  @@index([ingredient_id])
  @@map("recipe_item")
}

model HppSnapshot {
  id            Int      @id @default(autoincrement())
  recipe_id     Int
  total_hpp     Int
  variable_cost Int
  fixed_cost    Int
  note          String?
  created_at    DateTime @default(now())
  recipe        Recipe   @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@map("hpp_snapshot")
}

model DailySummary {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  revenue        Int      @default(0)
  net_revenue    Int      @default(0)
  cogs           Int      @default(0)
  expenses       Int      @default(0)
  total_orders   Int      @default(0)
  top_menus_json Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([date])
  @@map("daily_summary")
}

enum CategoryType {
  FOOD
  DRINK
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  STAFF
}

enum PlatformType {
  OFFLINE
  DELIVERY
}

enum PaymentMethodType {
  CASH
  QRIS
  BANK_TRANSFER
  E_WALLET
  OTHER
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum RecipeType {
  STANDARD
  COMPONENT
}

enum RecipeItemType {
  INGREDIENT
  COMPONENT
}
