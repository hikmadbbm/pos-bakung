generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int               @id @default(autoincrement())
  name          String
  username      String            @unique
  email         String?
  password      String
  role          Role              @default(CASHIER)
  pin           String?
  phone_number  String?
  status        String            @default("ACTIVE")
  profile_photo String?
  employee_id   String?
  notes         String?
  last_login    DateTime?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  activityLogs  UserActivityLog[]
  shifts        UserShift[]

  @@map("user")
}

model UserActivityLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  action_type String
  description String?
  ip_address  String?
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_activity_log")
}

model UserShift {
  id             Int       @id @default(autoincrement())
  user_id        Int
  start_time     DateTime  @default(now())
  end_time       DateTime?
  starting_cash  Int       @default(0)
  ending_cash    Int?
  expected_cash  Int?      @default(0)
  discrepancy    Int?      @default(0)
  note           String?
  cash_breakdown      Json?
  reconciliation_data Json?
  total_sales    Int       @default(0)
  status         String    @default("OPEN")
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([start_time])
  @@map("user_shift")
}

model StoreConfig {
  id             Int      @id @default(autoincrement())
  store_name     String   @default("BAKMIE YOU-TJE")
  address        String?  @default("Jl. Bakung No. 123, Jakarta")
  phone          String?  @default("0812-3456-7890")
  receipt_footer String?  @default("Thank you for visiting!\nPlease come again.")
  tax_rate       Float    @default(0)
  service_charge Float    @default(0)
  updated_at     DateTime @updatedAt

  @@map("storeconfig")
}

model Menu {
  id         Int           @id @default(autoincrement())
  name       String
  price      Int
  created_at DateTime      @default(now())
  categoryId Int?
  is_active  Boolean       @default(true)
  cost       Int
  category   MenuCategory? @relation(fields: [categoryId], references: [id])
  prices     MenuPrice[]
  orderItems OrderItem[]
  recipe     Recipe?

  @@map("menu")
}

model MenuCategory {
  id    Int    @id @default(autoincrement())
  name  String
  color String
  menus Menu[]

  @@map("menucategory")
}

model Platform {
  id              Int          @id @default(autoincrement())
  name            String
  type            PlatformType @default(OFFLINE)
  commission_rate Float        @default(0)
  created_at      DateTime     @default(now())
  menuPrices      MenuPrice[]
  orders          Order[]

  @@map("platform")
}

model MenuPrice {
  id          Int      @id @default(autoincrement())
  menu_id     Int
  platform_id Int
  price       Int
  menu        Menu     @relation(fields: [menu_id], references: [id], onDelete: Cascade)
  platform    Platform @relation(fields: [platform_id], references: [id], onDelete: Cascade)

  @@unique([menu_id, platform_id])
  @@index([platform_id])
  @@map("menuprice")
}

model Order {
  id                   Int            @id @default(autoincrement())
  order_number         String?        @unique @default(uuid())
  date                 DateTime       @default(now())
  total                Int
  commission           Int            @default(0)
  net_revenue          Int            @default(0)
  platform_id          Int?
  payment_method       String         @default("CASH")
  money_received       Int            @default(0)
  change_amount        Int            @default(0)
  status               String         @default("COMPLETED")
  note                 String?
  customer_name        String?
  discount             Int            @default(0)
  created_by_user_id   Int?
  processed_by_user_id Int?
  payment_method_id    Int?
  discount_rate        Float          @default(0)
  discount_type        String         @default("FIXED")
  paymentMethod        PaymentMethod? @relation(fields: [payment_method_id], references: [id])
  platform             Platform?      @relation(fields: [platform_id], references: [id])
  orderItems           OrderItem[]

  @@index([date])
  @@index([status])
  @@index([payment_method_id])
  @@index([platform_id])
  @@map("order")
}

model PaymentMethod {
  id             Int               @id @default(autoincrement())
  name           String
  type           PaymentMethodType @default(CASH)
  account_number String?
  account_name   String?
  description    String?
  imageUrl       String?
  qris_data      String?
  is_active      Boolean           @default(true)
  display_order  Int               @default(0)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  orders         Order[]

  @@map("paymentmethod")
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  order_id Int
  menu_id  Int
  qty      Int
  price    Int
  cost     Int
  menu     Menu  @relation(fields: [menu_id], references: [id])
  order    Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([menu_id])
  @@index([order_id])
  @@index([price])
  @@map("orderitem")
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  item        String
  category    String
  amount      Int
  description String?

  @@map("expense")
}

model FixedCost {
  id        Int     @id @default(autoincrement())
  name      String
  amount    Int
  frequency String
  is_active Boolean @default(true)

  @@map("fixedcost")
}

model CashierReconciliation {
  id           Int      @id @default(autoincrement())
  date         DateTime @unique
  opening_cash Int      @default(0)
  closing_cash Int      @default(0)
  total_system Int      @default(0)
  total_actual Int      @default(0)
  discrepancy  Int      @default(0)
  notes        String?
  submitted_by String?
  status       String   @default("SUBMITTED")
  details      Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("cashierreconciliation")
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  STAFF
}

enum PlatformType {
  OFFLINE
  DELIVERY
}

enum PaymentMethodType {
  CASH
  QRIS
  BANK_TRANSFER
  E_WALLET
  OTHER
}

model Ingredient {
  id                Int                      @id @default(autoincrement())
  category          String
  item_name         String
  brand             String
  volume            Float                    // Packaging size/volume
  unit              String                   // e.g., "kg", "gr", "ml", "pcs"
  price             Int                      // Latest purchase price
  cost_per_unit     Float                    @default(0) // price / volume
  stock             Float                    @default(0)
  minimum_stock     Float                    @default(0)
  purchase_location String?
  purchase_link     String?
  notes             String?
  created_at        DateTime                 @default(now())
  updated_at        DateTime                 @updatedAt
  price_history     IngredientPriceHistory[]
  recipe_items      RecipeItem[]
  purchases         Purchase[]
  stock_movements   StockMovement[]

  @@map("ingredient")
}

model IngredientPriceHistory {
  id                    Int        @id @default(autoincrement())
  ingredient_id         Int
  price                 Int
  date                  DateTime   @default(now())
  reference_purchase_id Int?
  ingredient            Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  purchase              Purchase?  @relation(fields: [reference_purchase_id], references: [id])

  @@map("ingredient_price_history")
}

model Purchase {
  id              Int                      @id @default(autoincrement())
  purchase_date   DateTime                 @default(now())
  ingredient_id   Int
  quantity        Float
  unit            String
  volume          Float                    @default(1.0) // Units per quantity (e.g., 25kg per sack)
  unit_price      Int
  total_price     Int
  supplier        String?
  notes           String?
  created_at      DateTime                 @default(now())
  ingredient      Ingredient               @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  price_histories IngredientPriceHistory[]
  stock_movements StockMovement[]

  @@index([ingredient_id])
  @@map("purchase")
}

model StockMovement {
  id              Int          @id @default(autoincrement())
  ingredient_id   Int
  movement_type   MovementType
  quantity        Float
  unit            String
  reference_id    Int?         // Purchase ID or other ref
  reference_type  String?      // e.g., "PURCHASE", "RECIPE_USAGE", "ADJUSTMENT"
  created_at      DateTime     @default(now())
  ingredient      Ingredient   @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  purchase        Purchase?    @relation(fields: [reference_id], references: [id])

  @@index([ingredient_id])
  @@index([created_at])
  @@map("stock_movement")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum RecipeType {
  STANDARD
  COMPONENT
}

enum RecipeItemType {
  INGREDIENT
  COMPONENT
}

model Recipe {
  id              Int                @id @default(autoincrement())
  name            String
  type            RecipeType         @default(STANDARD)
  menu_id         Int?               @unique
  menu            Menu?              @relation(fields: [menu_id], references: [id])
  base_quantity   Float              @default(1) // Usually 1 portion or yield
  monthly_fixed_cost Int           @default(0)
  monthly_production_volume Int    @default(0)
  cost_change_alert Float           @default(0) // Percentage change
  total_variable_cost Int            @default(0)
  fixed_cost_allocation Int          @default(0)
  total_hpp       Int                @default(0)
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  items           RecipeItem[]       @relation("RecipeToItems")
  used_in_items   RecipeItem[]       @relation("ComponentToItems")
  snapshots       HppSnapshot[]

  @@map("recipe")
}

model RecipeItem {
  id                  Int            @id @default(autoincrement())
  recipe_id           Int
  item_type           RecipeItemType @default(INGREDIENT)
  ingredient_id       Int?
  component_recipe_id Int?
  quantity            Float
  unit                String?        // Usage unit (e.g. gr)
  recipe              Recipe         @relation("RecipeToItems", fields: [recipe_id], references: [id], onDelete: Cascade)
  ingredient          Ingredient?    @relation(fields: [ingredient_id], references: [id])
  component_recipe    Recipe?        @relation("ComponentToItems", fields: [component_recipe_id], references: [id])

  @@map("recipe_item")
}

model HppSnapshot {
  id              Int      @id @default(autoincrement())
  recipe_id       Int
  total_hpp       Int
  variable_cost   Int
  fixed_cost      Int
  note            String?
  created_at      DateTime @default(now())
  recipe          Recipe   @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@map("hpp_snapshot")
}
model DailySummary {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique
  revenue         Int      @default(0)
  net_revenue     Int      @default(0)
  cogs            Int      @default(0)
  expenses        Int      @default(0)
  total_orders    Int      @default(0)
  top_menus_json  Json?    // Store JSON of top menus for that day
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([date])
  @@map("daily_summary")
}
